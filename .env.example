# ============================================
# Forum API 环境配置示例
# 复制本文件为 .env，然后填入实际配置
# ============================================

# FastAPI 应用配置
FORUM_HOST=127.0.0.1
FORUM_PORT=8000
FORUM_BASE_URL=http://127.0.0.1:8000

# JWT 安全密钥（生产环境务必使用复杂的随机字符串）
FORUM_SECRET_KEY=your-super-safe-and-long-secret-key-change-in-production

# ============================================
# MySQL 数据库配置
# ============================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=forum_db
DB_AUTOCOMMIT=True

# ============================================
# Redis 配置
# ============================================
REDIS_URL=redis://127.0.0.1:6379/0

# ============================================
# 性能测试配置
# ============================================
FORUM_PERF_USER_COUNT=1200
